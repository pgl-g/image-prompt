{
  "name": "vision-prompt",
  "displayName": "VisionPrompt",
  "version": "0.0.1",
  "description": "双向生图引擎：右键图片智能生成提示词，提示词一键生成图片",
  "author": "顾孝标",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "lucide-react": "^1.7.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "contextMenus",
      "storage",
      "scripting"
    ],
    "host_permissions": [
      "https://*/*"
    ]
  }
}
